# Alpaca API credentials (get from app.alpaca.markets)
# WARNING: Never commit real credentials to Git!
# Get yours from: https://app.alpaca.markets/account/api
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Trading mode
MODE=paper                    # paper | live

# Symbols to trade (comma-separated)
SYMBOLS=SPY,QQQ,AAPL,TSLA,NVDA

# Risk management
DAILY_LOSS_CAP=-0.02          # -2% of equity = hard stop for the day
MAX_CONCURRENT_POSITIONS=5
PER_TRADE_STOP_LOSS=-0.003    # -0.3% per trade
OPTIONS_MAX_DELTA=0.5

# Cooldown after loss streak
COOLDOWN_TRADES=3             # 3 consecutive losses trigger cooldown
COOLDOWN_MINUTES=15

# ML model path (will be created after training)
ML_MODEL_PATH=engine/models/scalp_v1.onnx

# API server (for iOS communication)
API_HOST=0.0.0.0
API_PORT=8765
API_LOG_LEVEL=info

# Backtesting config
BACKTEST_LOOKBACK_DAYS=365
BACKTEST_TRAIN_DAYS=60
BACKTEST_TEST_DAYS=10

# Options trading (opt-in)
# NOTE: Alpaca paper accounts do NOT support real options orders.
#       Set PAPER_OPTIONS_SIM=true (default) to simulate fills locally
#       so iOS stats populate during development without a live account.
#       For live options trading, set MODE=live and PAPER_OPTIONS_SIM=false.
ZERO_DTE_ENABLED=false        # enable 0DTE SPY credit spread strategy
PAPER_OPTIONS_SIM=true        # simulate option fills in paper mode

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/engine.log
